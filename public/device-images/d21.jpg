</div>
<div class="cmp-p-text">

  			 <style>
// Overrides
#homepage .cmp-teaser {
    border-radius: 0;
}
.cmp-p-container  .cmp-separator .cmp-separator__horizontal-rule {
    margin-left: 16px;
    margin-right: 16px;
}
.xfpage.page.basicpage .container .cmp-p-container .cmp-container {
    padding: 0;
}
.dynamic-offer .cmp-p-chromelesspage .cmp-p-container .cmp-container {
    padding: 0;
}
.offer-content.web-offer.hr .dm-dynamic-offer.dm-img-bkg.cmp-teaser {
    border-radius: 0;
}
.offer-content.web-offer.pc .dm-dynamic-offer.dm-img-bkg.cmp-teaser {
    border-radius: 4px;
}
.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-lc .dm-dynamic-offer .offer-text {
	max-width: 100%
}
.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-lc .dm-dynamic-offer .offer-bkg-img {
	max-width: 100%
}
.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-lc .dm-dynamic-offer {
	max-width: 100%
}
.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-lc {
	max-width: 100%
}
.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-sc .dm-dynamic-offer {
	max-width: 100%;
}
.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-sc {
	max-width: 100%;
	margin-top: -1px;
	border-radius: 4px;
	margin-left: 0;
}
.offer-body .offer-content.hr .dm-dynamic-offer .offer-text .offer-headline {
        max-width: 65%;
}
@media (max-width: 991px) {
	.offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-sc {
		max-width: 100%;
		margin-top: 0;
		border-radius: 4px;
		margin-left: -1px;
	}
	.tf-hp-edu-lc .dm-dynamic-offer.dm-img-bkg.cmp-teaser {
	    border-radius: 4px 0 0 4px;
	}
	.tf-hp-edu-sc .dm-dynamic-offer.dm-img-none.cmp-teaser {
	    border-radius: 0 4px 4px 0;
	}
}
@media (max-width: 768px) {
        .offer-body.dm-tf-hp-edu .offer-content.tf-hp-edu-sc {
            margin-left: 0;
        }
        .offer-body .offer-content.hr .dm-dynamic-offer .offer-text .offer-headline {
                max-width: 100%;
        }
}
.section-titles a {display:inline-block}
.section-titles h2 {display:inline-block; margin-right: 14px;}
// Blog styles
.post-list {
	margin-top: 24px;
}
.post {
	border-bottom: 1px solid #dcdcdc;
	margin-bottom: 48px;
	padding-bottom: 48px;
	position: relative;
}
.pull-left {
	display: inline-block;
	margin-right: 5%;
}
.pull-left img {
        border-radius: 4px;
        height: 100px;
        width: auto;
        object-fit: cover;
}
.pull-right {
	float: right;
}
.post-content {
	display: inline-block;
	position: absolute;
	left: 180px;
	width: 100%;
        padding-right: 196px;
}
.post-content .post-title {
	font-size: 18px;
	font-weight: 500;
	line-height: 23px;
	margin-bottom: 8px;
	min-height: 70px;
}
.post-content a {
	color: #222222;
}
@media (max-width: 576px) {
        .post-content {
                left: 120px;
                padding-right: 110px;
       }
        .post-content .post-title {
               min-height: auto;
               font-size: 16px;
               line-height: 20px;
               margin-bottom: 0;
        }
       .pull-left{ font-size: 12px;}
       .pull-right {
               font-size: 12px;
               margin-top:2px
        }
        .pull-left img {
               min-height: auto;
               height: 70px
        }
}
</style>    


    
</div>
<div class="cmp-p-text">

  			 <div class="post-list" id="blog-template">
</div>
    


    
</div>
<div class="cmp-p-text">

  			 <script>
!function ($) {
$(document).ready(function () {
loadBlog();
}); // To ensure the script runs when the document is ready!

}(window.$j);

function loadBlog() {
var container = $('#blog-template');

$.ajax({
dataType: 'json',
url: 'https://admin.acceleratingscience.com/wp-json/as-api/v1/blog-feed',
response: {
format: 'json',
},
cache: false,
success: function(response) {

$.each(response, function (i) {
var title = response[i].title,
link = response[i].link,
date = response[i].post_date,
thumbnail = response[i].thumbnail;
img = encodeURI(decodeURIComponent(thumbnail[0]))

$(container).append(
'<div class="post"><a class="pull-left" href="' + link + '" title="Read more... ' + title + '"><img src="' + thumbnail[0] + '" alt="' + title + '" /></a><div class="post-content"><p class="post-title">' + title + '</p><span class="pull-left date">' + date + '</span><a class="pull-right" href="' + link + '" title="Read more › ' + title + '">Read more ›</a></div></div>'
);

});
},
error: function() {
$("#blog-template").html('<a href="https://www.thermofisher.com/blog/behindthebench/" class="em-img" data-trkr="blog-content-container-bkup"><img src="/content/dam/LifeTech/global/home-page/2017/06-jun/hp-featured-blog-category-behind-the-bench.jpg" alt="Featured blog category: Behind the bench" /></a>')
}
});
}

</script>    


    
</div>

        
		

