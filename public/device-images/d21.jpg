  }

  .dm-dynamic-offer.dm-img-bkg .offer-text {
    position: absolute;
    left: 0;
  }

  .dm-dynamic-offer.dm-img-bkg .offer-dynamic-product-image {
    position: absolute;
    left: 0;
  }

